            "properties": {}
          },
          {
            "id": "WriteHttpResponse1",
            "type": "Elsa.Http.WriteHttpResponse",
            "displayName": "Return Completed",
            "properties": {}
          }
        ]
      },
      {
        "id": "Sequence2",
        "type": "Elsa.Sequence",
        "displayName": "Manual review",
        "activities": [
          {
            "id": "SendEmail1",
            "type": "Elsa.Email.SendEmail",
