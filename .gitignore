# ── .NET build output ─────────────────────────────────────────────────────────
bin/
obj/
[Dd]ebug/
[Rr]elease/
*.user
*.suo
.vs/

# ── Test / coverage / docs artifacts ──────────────────────────────────────────
[Tt]est[Rr]esults/
reports/
docs/_site/
docs/api/
docs/.cache/
docs/test-results/coverage/     # generated by build-reports.sh
docs/test-results/tests/        # generated by build-reports.sh
src/web/dist/                   # DocFX site output (copied to dist/broker by make)

# ── Secrets & certificates (NEVER commit) ─────────────────────────────────────
certs/
*.pfx
*.p12
*.key
*.crt
*.pem
appsettings.*.local.json

# ── OS / editor cruft ─────────────────────────────────────────────────────────
.DS_Store
*.swp
